---
import { getLocaleFromUrl, localizePath, withBase } from '../config/site';
import { cleanContentSlug } from '../config/i18n';
import { getEntryDescription, getEntryTitle } from '../utils/content';

interface Props {
	post: {
		id: string;
		body?: string;
		data: {
			title: string;
			description: string;
			pubDate: Date;
			tags: string[];
			series?: string;
			cover?: string;
		};
	};
}

const { post } = Astro.props;
const locale = getLocaleFromUrl(Astro.url);
const title = getEntryTitle(post);
const description = getEntryDescription(post);
const cleanSlug = cleanContentSlug(post.id);
const transitionName = `blog-title-${cleanSlug.replace(/[^a-zA-Z0-9_-]/g, '-')}`;
const dateLocale = locale === 'zh' ? 'zh-CN' : 'en';
const date = post.data.pubDate.toLocaleDateString(dateLocale, {
	year: 'numeric',
	month: 'long',
	day: 'numeric',
});
const coverSrc = post.data.cover ? withBase(post.data.cover) : undefined;
---

<a
	href={localizePath(locale, `/blog/${cleanSlug}`)}
	class="group grid gap-4 border-t border-white/10 py-6 transition hover:border-white/30 md:grid-cols-[160px_1fr]"
>
	<div class="space-y-3">
		<p class="text-sm text-zinc-500">{date}</p>
	</div>
	<div>
		{coverSrc && (
			<img
				src={coverSrc}
				alt=""
				class="mb-5 aspect-[16/7] w-full rounded-lg border border-white/10 bg-zinc-900 object-cover opacity-90 transition group-hover:border-white/25 group-hover:opacity-100"
				loading="lazy"
				decoding="async"
			/>
		)}
		<div class="flex flex-wrap items-center gap-3">
			<h3 class="text-xl font-semibold text-white transition group-hover:text-zinc-200" transition:name={transitionName}>{title}</h3>
			{post.data.series && (
				<span class="rounded-full border border-emerald-400/25 bg-emerald-400/10 px-3 py-1 text-xs font-medium text-emerald-200">
					{post.data.series}
				</span>
			)}
		</div>
		<p class="mt-3 text-sm leading-6 text-zinc-400">{description}</p>
		<div class="mt-4 flex flex-wrap gap-2">
			{post.data.tags.map((tag) => (
				<span class="rounded-full border border-blue-400/25 bg-blue-400/10 px-3 py-1 text-xs font-medium text-blue-200">#{tag}</span>
			))}
		</div>
	</div>
</a>
