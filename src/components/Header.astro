---
import { getLocaleFromUrl, getSiteConfig } from '../config/site';

const locale = getLocaleFromUrl(Astro.url);
const siteConfig = getSiteConfig(locale);
const headerCtaHref = 'https://github.com/sswewe111';
---

<header class="sticky top-0 z-50 border-b border-white/10 bg-black/80 backdrop-blur-xl" transition:name="site-header" transition:animate="none">
	<nav class="mx-auto flex max-w-6xl items-center justify-between px-5 py-4">
		<a href="/" class="text-sm font-semibold uppercase tracking-[0.28em] text-white">
			{siteConfig.name}
		</a>
		<div class="hidden items-center gap-1 md:flex">
			{siteConfig.nav.map((item) => (
				<a
					href={item.href}
					class="rounded-full px-3 py-2 text-sm text-zinc-400 transition hover:bg-white/10 hover:text-white"
				>
					{item.label}
				</a>
			))}
		</div>
		<a
			href={headerCtaHref}
			target="_blank"
			rel="noreferrer"
			class="rounded-full border border-white/15 px-4 py-2 text-sm text-white transition hover:border-white/40 hover:bg-white hover:text-black"
		>
			{siteConfig.ui.headerCta}
		</a>
	</nav>
	<div class="flex gap-1 overflow-x-auto px-5 pb-3 md:hidden">
		{siteConfig.nav.map((item) => (
			<a href={item.href} class="shrink-0 rounded-full bg-white/5 px-3 py-1.5 text-sm text-zinc-300">
				{item.label}
			</a>
		))}
	</div>
</header>
