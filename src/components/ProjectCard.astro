---
import { getLocaleFromUrl, getSiteConfig, localizePath } from '../config/site';
import { cleanContentSlug } from '../config/i18n';

const locale = getLocaleFromUrl(Astro.url);
const siteConfig = getSiteConfig(locale);

interface Props {
	project: {
		id: string;
		data: {
			title: string;
			description: string;
			date: Date;
			tags: string[];
			role: string;
			featured?: boolean;
		};
	};
	variant?: 'compact' | 'wide';
}

const { project, variant = 'compact' } = Astro.props;
const cleanSlug = cleanContentSlug(project.id);
const transitionName = `project-title-${cleanSlug.replace(/[^a-zA-Z0-9_-]/g, '-')}`;
---

{variant === 'wide' ? (
	<a
		href={localizePath(locale, `/projects/${cleanSlug}`)}
		class="group grid min-h-[280px] overflow-hidden rounded-lg border border-white/10 bg-white/[0.035] transition hover:-translate-y-1 hover:border-white/30 hover:bg-white/[0.06] md:grid-cols-[minmax(0,1fr)_260px]"
	>
		<div class="flex flex-col justify-between p-6 md:p-8">
			<div>
				<p class="text-xs font-medium uppercase tracking-[0.2em] text-zinc-500">{project.data.role}</p>
				<h3 class="mt-5 text-3xl font-semibold leading-tight text-white" transition:name={transitionName}>{project.data.title}</h3>
				<p class="mt-5 max-w-2xl text-sm leading-7 text-zinc-400">{project.data.description}</p>
			</div>

			<p class="mt-8 inline-flex w-fit items-center border-b border-white/30 pb-1 text-sm font-medium text-white opacity-80 transition group-hover:translate-x-1 group-hover:opacity-100">
				{siteConfig.ui.projectCta}
			</p>
		</div>

		<aside class="flex flex-col justify-between border-t border-white/10 bg-black/20 p-6 md:border-l md:border-t-0 md:p-7">
			<div>
				<p class="text-xs font-medium uppercase tracking-[0.2em] text-zinc-500">Year</p>
				<p class="mt-2 text-2xl font-semibold text-white">{project.data.date.getFullYear()}</p>
			</div>
			<div class="mt-8">
				<p class="text-xs font-medium uppercase tracking-[0.2em] text-zinc-500">Tags</p>
				<div class="mt-4 flex flex-wrap gap-2">
					{project.data.tags.map((tag) => (
						<span class="rounded-full border border-blue-400/20 bg-blue-400/10 px-3 py-1 text-xs font-medium text-blue-100">{tag}</span>
					))}
				</div>
			</div>
		</aside>
	</a>
) : (
	<a
		href={localizePath(locale, `/projects/${cleanSlug}`)}
		class="group block rounded-lg border border-white/10 bg-white/[0.03] p-6 transition hover:-translate-y-1 hover:border-white/30 hover:bg-white/[0.06]"
	>
		<div class="flex items-center justify-between gap-4">
			<p class="text-sm text-zinc-500">{project.data.role}</p>
			<p class="text-sm text-zinc-500">{project.data.date.getFullYear()}</p>
		</div>
		<h3 class="mt-5 text-xl font-semibold text-white" transition:name={transitionName}>{project.data.title}</h3>
		<p class="mt-3 text-sm leading-6 text-zinc-400">{project.data.description}</p>
		<div class="mt-6 flex flex-wrap gap-2">
			{project.data.tags.map((tag) => (
				<span class="rounded-full border border-white/10 px-3 py-1 text-xs text-zinc-300">{tag}</span>
			))}
		</div>
		<p class="mt-6 text-sm text-white opacity-80 transition group-hover:opacity-100">{siteConfig.ui.projectCta}</p>
	</a>
)}
