---
import { getLocaleFromUrl, getSiteConfig, localizePath } from '../config/site';
import { cleanContentSlug } from '../config/i18n';

const locale = getLocaleFromUrl(Astro.url);
const siteConfig = getSiteConfig(locale);

interface Props {
	project: {
		id: string;
		data: {
			title: string;
			description: string;
			date: Date;
			tags: string[];
			role: string;
			featured?: boolean;
		};
	};
}

const { project } = Astro.props;
const cleanSlug = cleanContentSlug(project.id);
const transitionName = `project-title-${cleanSlug.replace(/[^a-zA-Z0-9_-]/g, '-')}`;
---

<a
	href={localizePath(locale, `/projects/${cleanSlug}`)}
	class="group block rounded-lg border border-white/10 bg-white/[0.03] p-6 transition hover:-translate-y-1 hover:border-white/30 hover:bg-white/[0.06]"
>
	<div class="flex items-center justify-between gap-4">
		<p class="text-sm text-zinc-500">{project.data.role}</p>
		<p class="text-sm text-zinc-500">{project.data.date.getFullYear()}</p>
	</div>
	<h3 class="mt-5 text-xl font-semibold text-white" transition:name={transitionName}>{project.data.title}</h3>
	<p class="mt-3 text-sm leading-6 text-zinc-400">{project.data.description}</p>
	<div class="mt-6 flex flex-wrap gap-2">
		{project.data.tags.map((tag) => (
			<span class="rounded-full border border-white/10 px-3 py-1 text-xs text-zinc-300">{tag}</span>
		))}
	</div>
	<p class="mt-6 text-sm text-white opacity-80 transition group-hover:opacity-100">{siteConfig.ui.projectCta}</p>
</a>
