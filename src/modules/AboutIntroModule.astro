---
import SectionHeading from '../components/SectionHeading.astro';

interface Props {
	kicker?: string;
	heading: string;
	intro?: string;
	profileLabel: string;
	profile: string;
	paragraphs: readonly string[];
}

const { heading, intro, kicker, paragraphs, profile, profileLabel } = Astro.props;
---

<section class="mx-auto max-w-6xl px-5 py-20 md:py-28">
	<SectionHeading
		kicker={kicker}
		title={heading}
		description={intro}
	/>
	<div class="grid gap-8 md:grid-cols-[0.9fr_1.1fr]">
		<div class="rounded-lg border border-white/10 bg-white/[0.03] p-6">
			<p class="text-sm uppercase tracking-[0.24em] text-zinc-500">{profileLabel}</p>
			<p class="mt-4 text-2xl font-semibold leading-snug text-white">
				{profile}
			</p>
		</div>
		<div class="space-y-5 text-base leading-8 text-zinc-400">
			{paragraphs.map((paragraph) => <p>{paragraph}</p>)}
		</div>
	</div>
</section>
