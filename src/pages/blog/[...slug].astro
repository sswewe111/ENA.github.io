---
import { getCollection, render } from 'astro:content';
import MarkdownLayout from '../../layouts/MarkdownLayout.astro';
import { getBacklinks } from '../../utils/knowledge';
import { getEntryDescription, getEntryTitle } from '../../utils/content';
import { cleanContentSlug } from '../../config/i18n';

export const prerender = true;

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

	return posts.map((post) => ({
		params: { slug: post.id },
		props: { post },
	}));
}

const { post } = Astro.props;
const allPosts = await getCollection('blog');
const backlinks = getBacklinks(post.id, allPosts);
const { Content, headings } = await render(post);
const cleanSlug = cleanContentSlug(post.id);
const heroTransitionName = `blog-title-${cleanSlug.replace(/[^a-zA-Z0-9_-]/g, '-')}`;
const seriesPosts = post.data.series
	? allPosts
			.filter((item) => !item.data.draft && item.data.series === post.data.series)
			.sort((a, b) => getEntryTitle(a).localeCompare(getEntryTitle(b), 'zh-CN', { numeric: true }))
			.map((item) => ({
				id: item.id,
				title: getEntryTitle(item),
			}))
	: [];
---

<MarkdownLayout
	title={getEntryTitle(post)}
	description={getEntryDescription(post)}
	date={post.data.pubDate}
	tags={post.data.tags}
	cover={post.data.cover}
	backlinks={backlinks}
	heroTransitionName={heroTransitionName}
	headings={headings}
	currentId={post.id}
	series={post.data.series}
	seriesPosts={seriesPosts}
>
	<Content />
</MarkdownLayout>
