---
import { getCollection, render } from 'astro:content';
import MarkdownLayout from '../../../layouts/MarkdownLayout.astro';
import { cleanContentSlug } from '../../../config/i18n';
import { getBacklinks } from '../../../utils/knowledge';
import { getEntryDescription, getEntryTitle } from '../../../utils/content';

export const prerender = true;

export async function getStaticPaths() {
	const posts = (await getCollection('blog')).filter((post) => !post.data.draft);

	return posts.map((post) => ({
		params: { slug: cleanContentSlug(post.id) },
		props: { post },
	}));
}

const { post } = Astro.props;
const allPosts = await getCollection('blog');
const backlinks = getBacklinks(post.id, allPosts);
const { Content, headings } = await render(post);
const cleanSlug = cleanContentSlug(post.id);
const heroTransitionName = `blog-title-${cleanSlug.replace(/[^a-zA-Z0-9_-]/g, '-')}`;
---

<MarkdownLayout title={getEntryTitle(post)} description={getEntryDescription(post)} date={post.data.pubDate} tags={post.data.tags} cover={post.data.cover} backlinks={backlinks} heroTransitionName={heroTransitionName} headings={headings}>
	<Content />
</MarkdownLayout>
