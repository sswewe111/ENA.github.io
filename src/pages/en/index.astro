---
import Layout from '../../layouts/Layout.astro';
import PageRenderer from '../../components/PageRenderer.astro';
import { getLocaleFromUrl, getSiteConfig } from '../../config/site';

const locale = getLocaleFromUrl(Astro.url);
const siteConfig = getSiteConfig(locale);
const page = siteConfig.pages.home;
---

<Layout title={siteConfig.name} description={siteConfig.description}>
	<PageRenderer locale={locale} modules={page.modules} />
</Layout>
